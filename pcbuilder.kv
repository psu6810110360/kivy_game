<MenuButton@Button>:
    background_color: (0, 0, 0, 0)
    bold: True
    canvas.before:
        Color:
            rgba: (0.2, 0.25, 0.35, 1) if self.state == 'normal' else (0.1, 0.6, 0.8, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8]

<PartButton@Button>:
    size_hint_y: None
    height: "60dp"
    background_color: (0, 0, 0, 0)
    bold: True
    text_size: self.width - 20, None
    halign: 'left'
    valign: 'middle'
    canvas.before:
        Color:
            rgba: (0.18, 0.22, 0.28, 1) if self.state == 'normal' else (0.1, 0.5, 0.8, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

<MainMenu>:
    canvas.before:
        Color:
            rgba: (0.05, 0.05, 0.07, 1)
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        Label:
            text: "PC BUILDER TYCOON"
            font_size: '40sp'
            bold: True
            color: (0.2, 0.8, 1, 1)
            size_hint_y: 0.6
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            width: "300dp"
            height: self.minimum_height
            pos_hint: {'center_x': 0.5}
            Button:
                text: "CONTINUE"
                font_size: '18sp'
                bold: True
                size_hint_y: None
                height: "50dp" if root.has_started else 0
                opacity: 1 if root.has_started else 0
                disabled: not root.has_started
                on_release: app.root.current = 'main'
            Widget:
                size_hint_y: None
                height: "15dp" if root.has_started else 0
            Button:
                text: "NEW GAME"
                font_size: '18sp'
                bold: True
                size_hint_y: None
                height: "50dp"
                on_release: 
                    app.root.get_screen('main').reset_game()
                    root.has_started = True
                    app.root.current = 'main'
            Widget:
                size_hint_y: None
                height: "15dp"
            Button:
                text: "EXIT"
                font_size: '18sp'
                bold: True
                size_hint_y: None
                height: "50dp"
                on_release: app.stop()

<MainGame>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.05, 0.05, 0.07, 1)
            Rectangle:
                pos: self.pos
                size: self.size
        ActionBar:
            background_color: (0.1, 0.1, 0.15, 1)
            ActionView:
                ActionPrevious: 
                    title: "PC Workshop"
                    with_previous: True
                    on_release: app.root.current = 'menu'
        BoxLayout:
            size_hint_y: 0.22
            padding: 10
            spacing: 10
            BoxLayout:
                orientation: 'horizontal'
                size_hint_x: 0.4
                padding: 15
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        text: "WALLET"
                        font_size: '11sp'
                        color: (0.5, 0.5, 0.6, 1)
                    Label:
                        text: "$" + f"{int(root.money):,}"
                        font_size: '22sp'
                        bold: True
                        color: (0.2, 0.9, 0.5, 1) if root.money >= 0 else (1, 0.2, 0.2, 1)
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        text: "REPUTATION"
                        font_size: '11sp'
                        color: (0.5, 0.5, 0.6, 1)
                    Label:
                        text: str(int(root.reputation)) + "%"
                        font_size: '18sp'
                        bold: True
                        color: (1, 0.8, 0.2, 1)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.2
                padding: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                Label:
                    text: "DAY " + str(int(root.current_day))
                    bold: True
                Label:
                    text: "Cust: " + str(int(root.current_customer_idx)) + "/" + str(int(root.customers_today))
                Label:
                    text: root.active_event_name
                    color: (1, 0.8, 0.2, 1) if root.active_event_name != "Normal" else (0.5, 0.5, 0.6, 1)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.4
                padding: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                Label:
                    text: root.current_order
                    bold: True
                    font_size: '12sp'
                    color: (0.2, 0.8, 1, 1)
                GridLayout:
                    cols: 2
                    size_hint_y: 0.5
                    Label:
                        text: root.required_cpu_display
                        font_size: '10sp'
                    Label:
                        text: root.required_ram_display
                        font_size: '10sp'
                    Label:
                        text: root.required_gpu_display
                        font_size: '10sp'
                    Label:
                        text: root.required_storage_display
                        font_size: '10sp'
                BoxLayout:
                    size_hint_y: 0.3
                    Label:
                        text: "Rem: $" + str(int(root.budget_remaining))
                        font_size: '12sp'
                        bold: True
                    Button:
                        text: "SKIP"
                        size_hint_x: 0.4
                        on_release: root.skip_day()
        Label:
            size_hint_y: 0.05
            text: root.log_message
            bold: True
            canvas.before:
                Color:
                    rgba: (0.1, 0.5, 0.3, 1) if "Sold" in root.log_message or "Installed" in root.log_message else (0.2, 0.4, 0.8, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            orientation: 'horizontal'
            padding: 15
            spacing: 15
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.32
                padding: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                GridLayout:
                    cols: 4
                    size_hint_y: 0.2
                    spacing: 5
                    MenuButton:
                        text: "CPU"
                        on_release: root.set_category('CPU')
                    MenuButton:
                        text: "MB"
                        on_release: root.set_category('MB')
                    MenuButton:
                        text: "GPU"
                        on_release: root.set_category('GPU')
                    MenuButton:
                        text: "RAM"
                        on_release: root.set_category('RAM')
                    MenuButton:
                        text: "PSU"
                        on_release: root.set_category('PSU')
                    MenuButton:
                        text: "STRG"
                        on_release: root.set_category('Storage')
                    MenuButton:
                        text: "CASE"
                        on_release: root.set_category('Case')
                    MenuButton:
                        text: "ALL"
                        on_release: root.set_category('all')
                ScrollView:
                    StackLayout:
                        id: shop_list
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 8
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.38
                padding: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                Label:
                    text: "ASSEMBLY BENCH"
                    bold: True
                ScrollView:
                    GridLayout:
                        cols: 1
                        spacing: 5
                        size_hint_y: None
                        height: self.minimum_height
                        Label:
                            text: "CPU: " + root.installed_cpu
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "MB: " + root.installed_mb
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "GPU: " + root.installed_gpu
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "RAM: " + root.installed_ram
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "STRG: " + root.installed_storage
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "PSU: " + root.installed_psu
                            size_hint_y: None
                            height: 35
                        Label:
                            text: "CASE: " + root.installed_case
                            size_hint_y: None
                            height: 35
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.3
                padding: 15
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                Label:
                    text: "SYSTEM SPECS"
                    bold: True
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.3
                    Label:
                        text: str(int(root.total_wattage)) + "W"
                        font_size: '22sp'
                        bold: True
                        color: (1, 0.3, 0.3, 1) if root.pc_status == "Power overload!" else (0.2, 0.9, 0.5, 1)
                    ProgressBar:
                        max: 1200
                        value: root.total_wattage
                Label:
                    text: root.pc_status
                    color: (0.2, 0.9, 0.5, 1) if root.pc_status == "Ready to sell!" else (1, 0.8, 0.2, 1)
                Button:
                    text: "FULFILL ORDER"
                    size_hint_y: 0.3
                    bold: True
                    on_press: root.on_sell()
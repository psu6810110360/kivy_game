<MainMenu>:
    canvas.before:
        Color:
            rgba: (0.05, 0.05, 0.07, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 20
        
        Label:
            text: "PC BUILDER\n[color=#33ccff]TYCOON[/color]"
            markup: True
            font_size: '60sp'
            bold: True
            halign: 'center'
            size_hint_y: 0.6
            
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.4
            size_hint_x: 0.4
            pos_hint: {'center_x': 0.5}
            spacing: 15
            
            Button:
                text: "START GAME"
                font_size: '20sp'
                bold: True
                background_color: (0,0,0,0)
                background_normal: ''
                canvas.before:
                    Color:
                        rgba: (0.1, 0.7, 0.3, 1) if self.state == 'normal' else (0.05, 0.5, 0.2, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                on_release: 
                    app.root.transition.direction = 'left'
                    app.root.current = 'main'
                    
            Button:
                text: "EXIT"
                font_size: '20sp'
                bold: True
                background_color: (0,0,0,0)
                background_normal: ''
                canvas.before:
                    Color:
                        rgba: (0.8, 0.2, 0.2, 1) if self.state == 'normal' else (0.6, 0.1, 0.1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [10]
                on_release: app.stop()

<MenuButton@Button>:
    background_color: (0, 0, 0, 0)
    background_normal: ''
    bold: True
    color: (0.9, 0.9, 0.9, 1)
    canvas.before:
        Color:
            rgba: (0.2, 0.25, 0.35, 1) if self.state == 'normal' else (0.1, 0.6, 0.8, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8]

<PartButton@Button>:
    size_hint_y: None
    height: "60dp"
    background_color: (0, 0, 0, 0)
    background_normal: ''
    color: (1, 1, 1, 1)
    bold: True
    text_size: self.width - 20, None
    halign: 'left'
    valign: 'middle'
    canvas.before:
        Color:
            rgba: (0.18, 0.22, 0.28, 1) if self.state == 'normal' else (0.1, 0.5, 0.8, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

<MainGame>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: (0.05, 0.05, 0.07, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        ActionBar:
            background_color: (0.1, 0.1, 0.15, 1)
            ActionView:
                ActionPrevious: 
                    title: "PC BUILDER TYCOON - Workshop"
                    with_previous: True
                    app_icon: '' 
                    on_release: 
                        app.root.transition.direction = 'right'
                        app.root.current = 'menu'
                ActionButton: 
                    text: "NEW GAME"
                    bold: True
                    on_release: root.reset_game()

        BoxLayout:
            size_hint_y: 0.18
            padding: 15
            spacing: 15
            
            BoxLayout:
                orientation: 'horizontal'
                size_hint_x: 0.5
                padding: 15
                spacing: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        text: "WALLET"
                        font_size: '12sp'
                        bold: True
                        color: (0.5, 0.5, 0.6, 1)
                        size_hint_y: 0.3
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    Label:
                        text: "$" + f"{int(root.money):,}"
                        font_size: '26sp'
                        bold: True
                        color: (0.2, 0.9, 0.5, 1) if root.money >= 0 else (1, 0.2, 0.2, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        text: "REPUTATION"
                        font_size: '12sp'
                        bold: True
                        color: (0.5, 0.5, 0.6, 1)
                        size_hint_y: 0.3
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    BoxLayout:
                        spacing: 10
                        ProgressBar:
                            max: 100
                            value: root.reputation
                            size_hint_x: 0.7
                        Label:
                            text: str(int(root.reputation)) + "%"
                            font_size: '18sp'
                            bold: True
                            color: (1, 0.8, 0.2, 1)
                            size_hint_x: 0.3
                            text_size: self.size
                            halign: 'right'
                            valign: 'middle'

                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        text: "DAY"
                        font_size: '12sp'
                        bold: True
                        color: (0.5, 0.5, 0.6, 1)
                        size_hint_y: 0.3
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    Label:
                        text: str(int(root.current_day))
                        font_size: '26sp'
                        bold: True
                        color: (0.2, 0.8, 1, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
            
            # Section: Current Order
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.5
                padding: [15, 10, 15, 10]
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                Label:
                    text: "📋 CURRENT ORDER"
                    font_size: '12sp'
                    bold: True
                    color: (0.5, 0.5, 0.6, 1)
                    size_hint_y: 0.15
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                Label:
                    text: root.current_order
                    font_size: '15sp'
                    bold: True
                    color: (0.2, 0.8, 1, 1)
                    size_hint_y: 0.2
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                
                GridLayout:
                    cols: 2
                    size_hint_y: 0.35
                    Label:
                        text: root.required_cpu_display
                        font_size: '11sp'
                        color: (0.8, 0.8, 0.8, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    Label:
                        text: root.required_ram_display
                        font_size: '11sp'
                        color: (0.8, 0.8, 0.8, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    Label:
                        text: root.required_gpu_display
                        font_size: '11sp'
                        color: (0.8, 0.8, 0.8, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    Label:
                        text: root.required_storage_display
                        font_size: '11sp'
                        color: (0.8, 0.8, 0.8, 1)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                
                BoxLayout:
                    size_hint_y: 0.3
                    spacing: 10
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.65
                        Label:
                            text: "Build: $" + str(int(root.current_build_cost))
                            font_size: '13sp'
                            bold: True
                            color: (1, 0.6, 0.2, 1)
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                        Label:
                            text: "Remain: $" + str(int(root.budget_remaining))
                            font_size: '13sp'
                            bold: True
                            color: (0.2, 0.9, 0.5, 1) if root.budget_remaining >= 0 else (1, 0.3, 0.3, 1)
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                    Button:
                        text: "SKIP"
                        size_hint_x: 0.35
                        size_hint_y: 0.8
                        pos_hint: {'center_y': 0.5}
                        background_color: (0, 0, 0, 0)
                        background_normal: ''
                        font_size: '12sp'
                        bold: True
                        color: (1, 1, 1, 1)
                        canvas.before:
                            Color:
                                rgba: (0.8, 0.2, 0.2, 1) if self.state == 'normal' else (0.6, 0.1, 0.1, 1)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8]
                        on_release: root.skip_day()

        Label:
            size_hint_y: 0.05
            text: root.log_message
            font_size: '14sp'
            bold: True
            color: (1, 1, 1, 1)
            canvas.before:
                Color:
                    rgba: (0.1, 0.5, 0.3, 1) if "Sold for" in root.log_message else ((0.8, 0.2, 0.2, 1) if "mismatch" in root.log_message or "Not enough" in root.log_message or "BANKRUPT" in root.log_message else (0.2, 0.4, 0.8, 1))
                Rectangle:
                    pos: self.pos
                    size: self.size

        BoxLayout:
            orientation: 'horizontal'
            padding: 15
            spacing: 15

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.32
                padding: 10
                spacing: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                
                Label: 
                    text: "🛒 PARTS SHOP"
                    size_hint_y: 0.05
                    font_size: '14sp'
                    bold: True
                    color: (0.9, 0.9, 0.9, 1)
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                
                GridLayout:
                    cols: 4
                    size_hint_y: 0.15
                    spacing: 5
                    MenuButton:
                        text: "CPU"
                        on_release: root.set_category('CPU')
                    MenuButton:
                        text: "MB"
                        on_release: root.set_category('MB')
                    MenuButton:
                        text: "GPU"
                        on_release: root.set_category('GPU')
                    MenuButton:
                        text: "RAM"
                        on_release: root.set_category('RAM')
                    MenuButton:
                        text: "PSU"
                        on_release: root.set_category('PSU')
                    MenuButton:
                        text: "STRG"
                        on_release: root.set_category('Storage')
                    MenuButton:
                        text: "CASE"
                        on_release: root.set_category('Case')
                    MenuButton:
                        text: "ALL"
                        on_release: root.set_category('all')
                        canvas.before:
                            Color:
                                rgba: (0.2, 0.6, 0.4, 1) if self.state == 'normal' else (0.1, 0.8, 0.5, 1)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8]
                
                ScrollView:
                    StackLayout:
                        id: shop_list
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 8

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.38
                padding: 15
                spacing: 10
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                
                Label:
                    text: "🔧 ASSEMBLY BENCH"
                    size_hint_y: 0.05
                    font_size: '14sp'
                    bold: True
                    color: (0.9, 0.9, 0.9, 1)
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                
                ScrollView:
                    GridLayout:
                        cols: 1
                        spacing: 8
                        size_hint_y: None
                        height: self.minimum_height
                        
                        Label:
                            text: "  [color=#888888]CPU:[/color]  " + root.installed_cpu
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]MB:[/color]  " + root.installed_mb
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]GPU:[/color]  " + root.installed_gpu
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]RAM:[/color]  " + root.installed_ram
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]STRG:[/color]  " + root.installed_storage
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]PSU:[/color]  " + root.installed_psu
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]
                        Label:
                            text: "  [color=#888888]CASE:[/color]  " + root.installed_case
                            markup: True
                            size_hint_y: None
                            height: 40
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            font_size: '13sp'
                            bold: True
                            canvas.before:
                                Color:
                                    rgba: (0.18, 0.2, 0.25, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [8]

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.3
                padding: 15
                spacing: 15
                canvas.before:
                    Color:
                        rgba: (0.12, 0.12, 0.15, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                
                Label:
                    text: "⚡ SYSTEM SPECS"
                    size_hint_y: 0.05
                    font_size: '14sp'
                    bold: True
                    color: (0.9, 0.9, 0.9, 1)
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.3
                    canvas.before:
                        Color:
                            rgba: (0.16, 0.16, 0.2, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                    padding: 10
                    Label:
                        text: "Total Power Draw"
                        color: (0.6, 0.6, 0.7, 1)
                        font_size: '12sp'
                        text_size: self.size
                        halign: 'left'
                        valign: 'top'
                    BoxLayout:
                        Label:
                            text: str(int(root.total_wattage)) + "W"
                            color: (1, 0.3, 0.3, 1) if root.pc_status == "Power overload!" else (0.2, 0.9, 0.5, 1)
                            font_size: '22sp'
                            bold: True
                            size_hint_x: 0.4
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                        ProgressBar:
                            max: 1200
                            value: root.total_wattage
                            size_hint_x: 0.6
                
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: 0.25
                    canvas.before:
                        Color:
                            rgba: (0.16, 0.16, 0.2, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                    padding: 10
                    Label:
                        text: "Build Status"
                        color: (0.6, 0.6, 0.7, 1)
                        font_size: '12sp'
                        text_size: self.size
                        halign: 'left'
                    Label:
                        text: root.pc_status
                        color: (0.2, 0.9, 0.5, 1) if root.pc_status == "Ready to sell!" else ((1, 0.3, 0.3, 1) if root.pc_status == "Power overload!" else (1, 0.8, 0.2, 1))
                        font_size: '18sp'
                        bold: True
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                
                Widget:
                    size_hint_y: 0.1

                Button:
                    text: "✓ FULFILL ORDER"
                    background_color: (0, 0, 0, 0)
                    background_normal: ''
                    size_hint_y: 0.3
                    font_size: '16sp'
                    bold: True
                    color: (1, 1, 1, 1)
                    canvas.before:
                        Color:
                            rgba: (0.1, 0.7, 0.3, 1) if self.state == 'normal' else (0.05, 0.5, 0.2, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12]
                    on_press: root.on_sell_pc()